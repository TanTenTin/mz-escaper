# 이 파일을 .env 로 복사한 뒤 값을 채운다. .env 는 절대 커밋하지 않는다.
#
# 이 .env 는 "백엔드"(내가 호스팅하는 서버)용이다. 유저에게 배포하는 exe 에는 .env 가
# 없고, 키가 없으므로 자동으로 릴레이 모드가 된다.

# LLM 게이트웨이 API 키. 서버 프로세스 메모리에만 존재하며 브라우저로 나가지 않는다.
# 이 값이 있으면 백엔드 모드(게이트웨이 직접 호출), 없으면 릴레이 모드다.
LLM_API_KEY=sk-여기에-키를-넣는다

# 릴레이 모드일 때 요청을 넘길 백엔드 주소. 기본값은 config.rs 에 박혀 있다.
# 백엔드로 띄울 때는 이 값을 쓰지 않는다.
BACKEND_URL=https://mz.tan-kim.com

# OpenAI 호환 엔드포인트의 베이스 URL. 뒤에 /chat/completions 가 붙는다.
LLM_BASE_URL=https://llm.tan-kim.com/v1

# 사용할 모델. 말투 변환은 가벼운 작업이라 낮은 모델로 충분하다.
LLM_MODEL=gemini-2.0-flash

# 서버가 바인드할 주소. 공개 서비스라면 0.0.0.0, 로컬 전용이면 127.0.0.1.
BIND_ADDR=0.0.0.0:8080

# 리버스 프록시(nginx, Cloudflare 등) 뒤에 있으면 true.
# true 일 때만 X-Forwarded-For 헤더를 클라이언트 IP로 신뢰한다.
# 프록시가 없는데 true 로 두면 아무나 헤더를 위조해 레이트 리밋을 우회할 수 있다.
TRUST_PROXY=false

# IP당 레이트 리밋: RATE_WINDOW_SECS 초 동안 최대 RATE_MAX_REQUESTS 회.
RATE_MAX_REQUESTS=20
RATE_WINDOW_SECS=60

# 업데이트 매니페스트 주소. 기본값은 코드에 박혀 있다(GitHub Releases 의 latest).
# 배포된 exe 에는 .env 가 없으므로, 기본값이 없으면 업데이트가 꺼진 채로 나가기 때문이다.
#
# 아래처럼 빈 값으로 두면 업데이트 확인을 끈다. 개발 중에 매번 GitHub 을 때리지 않으려면 유용하다.
# 다른 주소로 바꾸려면 값을 채운다 (https 만 허용).
UPDATE_MANIFEST_URL=
